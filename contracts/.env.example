# Casper testnet livenet deploy config (copy to .env; .env is gitignored).
# Deploy:  cargo run --bin contracts_cli -- deploy

# Testnet RPC node. Options:
#  - CSPR.cloud (needs an API key on the URL/headers — check cspr.cloud account)
#  - A public Casper testnet node RPC (host:7777/rpc)
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud/rpc
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events/main

# Casper testnet chain id.
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Path to the deployer's ed25519 secret key (funded via faucet).
# Generated at ~/casper-keys/secret_key.pem
#   public key: 01f7a9a650276f0bbbb0dd59a2048cae7ff7976b6f4dad0a337c66d1d09e6aa5ab
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=/home/l3eki/casper-keys/secret_key.pem
